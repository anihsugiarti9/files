#!/bin/bash

# 1. Bersihkan sisa file lama
rm -rf ngrok* frp* > /dev/null 2>&1

# 2. Download dan Install FRPC
echo "Installing FRP Client..."
wget https://github.com/fatedier/frp/releases/download/v0.54.0/frp_0.54.0_linux_amd64.tar.gz > /dev/null 2>&1
tar -xvf frp_0.54.0_linux_amd64.tar.gz > /dev/null 2>&1
cd frp_0.54.0_linux_amd64

# 3. Generate Random Remote Port (Format: 3XXXX)
RAND_SUFFIX=$(shuf -i 0-9999 -n 1 | printf "%04d" $(cat))
MY_REMOTE_PORT="3$RAND_SUFFIX"

# 4. Buat konfigurasi frpc.toml
cat <<EOF > frpc.toml
serverAddr = "157.245.155.242"
serverPort = 7000

[[proxies]]
name = "rdp-random-$MY_REMOTE_PORT"
type = "tcp"
localIP = "127.0.0.1"
localPort = 3389
remotePort = $MY_REMOTE_PORT
EOF

# 5. Jalankan FRPC di background
nohup ./frpc -c ./frpc.toml > /dev/null 2>&1 &

echo "Installing Desktop Environment & Browsers..."
sudo apt update && sudo apt upgrade -y

# 6. FIX FIREFOX: Gunakan Mozilla PPA (Bukan Snap)
sudo add-apt-repository ppa:mozillateam/ppa -y
echo '
Package: *
Pin: release o=LP-PPA-mozillateam
Pin-Priority: 1001
' | sudo tee /etc/apt/preferences.d/mozilla-firefox
sudo apt update
sudo apt install firefox -y

# 7. Install Chrome & Tools
wget https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb > /dev/null 2>&1
sudo apt install ./google-chrome-stable_current_amd64.deb -f -y

# 8. Install XRDP & MATE
sudo apt-get install -y xrdp
sudo apt-get install mate-core mate-desktop-environment mate-notification-daemon -y
sudo sed -i.bak '/fi/a #xrdp multiple users configuration \n mate-session \n' /etc/xrdp/startwm.sh
sudo service xrdp restart

clear
echo "===================================================="
echo "Setup Selesai!"
echo "IP Server FRPS : 157.245.155.242"
echo "Remote Port    : $MY_REMOTE_PORT"
echo "Koneksi RDP    : 157.245.155.242:$MY_REMOTE_PORT"
echo "===================================================="
echo "Tips: Jika Firefox tetap tidak muncul di menu,"
echo "buka terminal di dalam RDP lalu ketik: firefox"
